FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      solverDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermalSolver
{
    type solidConduction;
    heatFluxSummary     off;
}

mechanicsSolver
{
    type smallStrain;
    forceSummary        off;  
    cylindricalStress   on; 

    multiMaterialCorrection
    {
        type                       uniform;
        defaultWeights             1;
        defaultWeightsGrad         0.0;
    }
}
         
neutronicsSolver
{
    type diffusion;
    // type fromLatestTime;
}   

burnup
{
    type Lassmann;
    // type fromPower;
}

rheology
{
    type byMaterial;
    thermalExpansion on;
    modifiedPlaneStrain off;
    planeStress     off;
}

heatSource
{
    type timeDependentLhgr;
    
    // timePoints  ( 0  1        35000 ); //hrs
    timePoints  ( 0  3600     1.26E+08  ); //sec
    lhgr        ( 0  20e3     10e3 );
    timeInterpolationMethod linear;
    
    useExternalReferenceDimensions on;
    zMin 0;
    zMax 3;
	volumeFraction 0.1;

    axialProfile
    {        
        type timeDependentTabulated;
        #include "axialProfile";
        axialInterpolationMethod linear;
        burnupInterpolationMethod linear;
    }
    
    radialProfile
    {
        // type    flat;
        type    fromBurnup;
    }
    
    materials ( fuel );
}

fastFlux
{
    type timeDependentAxialProfile;
    
    // timePoints  ( 0  1        35000 ); // hrs
    timePoints  ( 0  3600     1.26E+08  ); //sec
    fastFlux    ( 0  2e13     1e13 );
    timeInterpolationMethod linear;

    axialProfile
    {
        type flat;
    }

    materials ( fuel cladding );
}

gapGas
{
    type Frapcon;

    gapPatches ( fuelOuter cladInner );
    holePatches ();
    topFuelPatches    ( fuelTop);
    bottomFuelPatches ( fuelBottom);

    gapVolumeOffset 0.0;
    gasReserveVolume 0.0;
    gasReserveTemperature 290;
}

fissionGasRelease
{
    type SCIANTIX;
    nFrequency  1;
    relax       1;
    addToRegistry   true;
    
    SCIANTIX
    {
        iverification                                   0; // (0= no verification)
        igrain_growth                                   1; // (1 = ainscough)
        iinert_gas_behavior                             1; // (1= do IGB)
        igas_diffusion_coefficient                      1; // (1= Turnbull et al., 1988)
        iintra_bubble_evolution                         1; // (1=Pizzocri et al., 2018)
        ibubble_radius                                  1; // (1= Olander&Wongy, 2006)
        iresolution_rate                                1; // (1=Turnbull 1971)
        itrapping_rate                                  1; // (1= Ham 1958)
        inucleation_rate                                1; // (1= Baker 1971)
        isolver                                         1; // (1= SDA, Pizzocri et al., 2019)
        iformat_output                                  1; // (1 = output.txt, values separated by tabs)
        igrain_boundary_vacancy_diffusion_coefficient   1; // (1= Reynolds and Burton, 1979)
        igrain_boundary_behaviour                       1; // (1= do InterGranularGasBehavior - Pastore et al., 2013; Barani et al., 2017)
        igrain_boundary_micro_cracking                  1; // (1 = Barani et al., 2017)
        igrain_recrystallization                        0; // (0 = non active)
        ifuel_reactor_type                              0; // (0=UO2/PWR)
        igas_effective_coefficient                      1; // gas effective (=0) or single atom (=1)
        igas_sweeping                                   1; // add boundary gas sweeping
    }
}

sliceMapper             
{
    type autoAxialSlices;
}

globalOptions
{
    pinDirection            (0 0 1);
    reactorType             "LWR";
}

materials
{
    fuel
    {
        type                        UO2;

        thermalExpansion
        {
            type UO2Relap;
            Tref 293;
        }

        densification
        {
            type          UO2Frapcon;
            resinteringDensityChange    1;
        }

        swelling
        {
            type               UO2Frapcon;
        }

        relocation
        {
            type             UO2Frapcon;
            GapCold                     0.13e-3;
            DiamCold                    9.0e-3; // cold fuel diameter
            recoveryFraction            0.5;
            outerPatch                  "fuelOuter";
        }

        damage
        {
            type isotropicCracking;
            isotropicCracking           on;
            nCracksMax                  12;
        }

        enrichment                  0.045;
        rGrain                      5e-06;
        GdContent                   0.0;
        theoreticalDensity          10960;
        densityFraction             0.95;
        dishFraction                0.0;

        consitutiveLaw
        {
            type elasticity;
        }               
		
    }

    cladding
    {
        material                Zircaloy;

        thermalExpansion
        {
            type ZircaloyMatpro;
            Tref 293;
        }

        constitutiveLaw
        {
            type elasticity; 
            // type misesPlasticCreep;
            
            yieldStress
            // {
            //     type constant;
            //     sigmaY 250e6;
            // }
            {
                type            hardening;
                values          ( ( 0 2.5e+08 ) );
            }
            
            creep
            {
                type ZircaloyLimback;
                relax 0.9;
            }
        }  
    }
}

