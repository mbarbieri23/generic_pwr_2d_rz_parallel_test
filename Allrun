#!/bin/bash
# Determine OpenFOAM distribution from WM_PROJECT_VERSION
if [ -z "$WM_PROJECT_VERSION" ]; then
    echo "ERROR: WM_PROJECT_VERSION is not set. Is OpenFOAM sourced?" >&2
    exit 1
fi

if [[ "$WM_PROJECT_VERSION" == v* ]]; then
    FOAM_DIST="ESI"
elif [[ -n "$WM_PROJECT_VERSION" ]]; then
    FOAM_DIST="FOUNDATION"
else
    echo "ERROR: Could not determine OpenFOAM distribution from WM_PROJECT_VERSION='$WM_PROJECT_VERSION'" >&2
    exit 1
fi

. $WM_PROJECT_DIR/bin/tools/RunFunctions

parallel=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --parallel|--p|-p)
            parallel="true"
            nProc="$2"
            shift 2
            ;;
        --*)
            echo "Unknown option: $1"
            exit 1
            ;;
        *)
            echo "Unexpected argument: $1 (did you forget --parallel ?)"
            exit 1
            ;;
    esac
done

