    runApplication -o -s decompose foamDictionary system/decomposeParDict -entry method -set 'manual' &> /dev/null
    runApplication -o -s decompose foamDictionary system/decomposeParDict -entry manualCoeffs/dataFile -set \"cellToProcMap\" &> /dev/null
    # exit 0 
    
    runApplication -a -s decompose foamDictionary system/decomposeParDict -entry numberOfSubdomains -set $nProc &> /dev/null
    runApplication -a -s decompose foamDictionary system/decomposeParDict -entry hierarchicalCoeffs/n -set "(1 1 $nProc)" &> /dev/null

    runApplication -a -s decompose foamDictionary system/decomposeParDict -entry simpleCoeffs/n -set "(1 1 $nProc)" &> /dev/null
    
