FoamFile
{
    format          ascii;
    class           dictionary;
    note            "mesh decomposition control dictionary";
    object          decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains 512;

method          manual;

multiLevelCoeffs
{
    level0
    {
        numberOfSubdomains 64;
        method          scotch;
    }
    level1
    {
        numberOfSubdomains 4;
        method          scotch;
    }
}

simpleCoeffs
{
    n               ( 1 1 512 );
    delta           0.001;
}

hierarchicalCoeffs
{
    n               ( 1 1 512 );
    order           xyz;
    delta           0.001;
}

metisCoeffs
{
}

scotchCoeffs
{
}

manualCoeffs
{
    dataFile        "cellToProcMap";
}

structuredCoeffs
{
    patches         ( movingWall );
    method          scotch;
}


