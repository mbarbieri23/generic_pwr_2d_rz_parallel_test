FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     offbeat;

//- Run options:
startFrom       latestTime;
startTime       0;
stopAt          endTime;

// endTime         35000;
// deltaT          0.001;
// endTime         0.1;
// deltaT          0.01;
endTime         10;
deltaT          1;

//- Write options:
writeControl    timeStep;
writeInterval   1;/* 10; */
purgeWrite      1;/* 0; */
writeFormat     ascii;
writeCompression off;
timeFormat      general;
timePrecision   20;/* 8; */
writePrecision   6;

