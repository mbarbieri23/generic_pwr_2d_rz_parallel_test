FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      neutronFlux0;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
   
    ".*Front|.*Back"
    {
        type            wedge;
    }
    
    "cladInner|cladOuter"
    {
        type            fixedValue;
        value           uniform 0;
    }

    fuelInner
    {
        type            zeroGradient;
    }

    fuelOuter
    {
        type            fixedValue;
        value           uniform 1;
    }

    ".*Top|.*Bottom"
    {
        type            zeroGradient;
    }

    ".*_1"
    {
        type            zeroGradient;
    }


}


